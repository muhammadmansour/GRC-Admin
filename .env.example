# Environment configuration template.
# Copy this file to .env and fill in the values. The .env file is gitignored.
# server.js loads these at startup via loadEnv().

# ── Required ──────────────────────────────────────────────
# Google Gemini API key used for policy extraction / chat.
GEMINI_API_KEY=

# ── GRC platform ──────────────────────────────────────────
# Base URL of the GRC platform (no trailing slash needed).
# Default when unset: https://grc.wathbah.dev
GRC_API_URL=https://grc.wathbah.dev

# ── Google Cloud Storage (optional) ───────────────────────
# Bucket for legislative internal documents.
GCS_LEGISLATIVE_BUCKET=local-legislative-updates-docs
# Bucket for Policy Update Pipeline (PUP) report artifacts.
GCS_PUP_BUCKET=pup-data
# Path to the GCP service-account credentials JSON (for GCS access).
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# ── Optional ──────────────────────────────────────────────
# Explicit Chromium/Chrome path for Puppeteer (PDF rendering).
PUPPETEER_EXECUTABLE_PATH=
# Enable verbose policy update pipeline logs (any non-empty value).
POLICY_PIPELINE_LOGS=
